{
  "expo": {
    "name": "Aranya AI",
    "slug": "aranya-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aranyaai",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aranya.ai",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow Aranya to access your microphone for voice calls.",
        "NSCameraUsageDescription": "Allow Aranya to access your camera to photograph your crops.",
        "NSPhotoLibraryUsageDescription": "Allow Aranya to access your photos so you can attach them to messages."
      }
    },
    "android": {
      "package": "com.aranya.ai",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "@react-native-google-signin/google-signin",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "backgroundColor": "#ffffff",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Aranya to access your camera to take pictures of your crops."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Aranya to access your photos so you can attach them to messages.",
          "savePhotosPermission": "Allow Aranya to save photos to your gallery."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Aranya to access your photos to attach to messages.",
          "cameraPermission": "Allow Aranya to use your camera to photograph your crops."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5c89387-622a-4384-8b77-8442797972e7"
      }
    }
  }
}
