{
  "expo": {
    "name": "Aranya AI",
    "slug": "aranya-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aranyaai",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aranya.ai",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow Aranya to access your microphone for voice calls.",
        "NSCameraUsageDescription": "Allow Aranya to access your camera to photograph your crops.",
        "NSPhotoLibraryUsageDescription": "Allow Aranya to access your photos so you can attach them to messages."
      }
    },
    "android": {
      "package": "com.aranya.ai",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-localization",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Aranya to access your microphone to listen to you during voice calls."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Aranya to access your camera to take pictures of your crops."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Aranya to access your photos so you can attach them to messages.",
          "savePhotosPermission": "Allow Aranya to save photos to your gallery."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Aranya to access your photos to attach to messages.",
          "cameraPermission": "Allow Aranya to use your camera to photograph your crops."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a97c5e3-f55a-483c-a196-64cf91ebacb8"
      }
    }
  }
}
