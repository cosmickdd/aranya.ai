TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
GEMINI_API_KEY=your_gemini_api_key
SARVAM_API_KEY=your_sarvam_api_key

# Your public ngrok/server URL (no trailing slash)
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app

# Optional: Live mandi prices from Government of India AGMARKNET
# Get free key at: https://data.gov.in/user/register
DATA_GOV_API_KEY=

# Optional: Live weather (1000 free calls/day)
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Production settings
PORT=5000
USE_PRODUCTION_SERVER=false        # Set true to use waitress instead of Flask dev server
VALIDATE_TWILIO_SIGNATURE=false    # Set true in production to verify requests are from Twilio
TEST_CALL_SECRET=                  # Secret header required to use /test-call endpoint
