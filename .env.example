# ─────────────────────────────────────────────────────────────────────
# Aranya.ai Configuration — Copy to .env and fill in your credentials
# ─────────────────────────────────────────────────────────────────────

# Twilio Account Credentials
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Google Gemini API
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Public URL for Twilio webhooks
# Local dev: https://xxxx.ngrok-free.app
# Production: https://your-domain.com or https://your-app.azurewebsites.net
PUBLIC_URL=https://utility-crinkly-uneasily.ngrok-free.dev

# Optional: Live mandi prices (free)
# Get from: https://data.gov.in/user/register
DATA_GOV_API_KEY=

# Optional: Live weather (free 1000 calls/day)
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Deployment Environment (set automatically by Azure)
# ─────────────────────────────────────────────────────────────────────
# ENVIRONMENT=production
# APP_NAME=aranya-ai
# REGION=eastus
